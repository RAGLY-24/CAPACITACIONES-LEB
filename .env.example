# Variables usadas por docker-compose.prod.yml (copiar a ".env" en la raíz).
# Deben coincidir con DB_DATABASE / DB_USERNAME / DB_PASSWORD en
# backend-capacitaciones/.env, ya que ese archivo es el que usa Laravel
# para conectarse a este mismo contenedor de base de datos.

DB_DATABASE=capacitaciones_db
DB_USERNAME=leb
DB_PASSWORD=cambia-esta-clave
DB_ROOT_PASSWORD=cambia-esta-clave-root

# Puerto público donde quedará expuesta la API (nginx -> php-fpm)
API_PORT=8000

# Puerto público donde quedará expuesto el frontend (React build + nginx)
WEB_PORT=80

# URL pública de la API que el frontend usará en tiempo de compilación
# (debe ser accesible desde el navegador del usuario final, no "localhost").
VITE_API_URL=http://localhost:8000
